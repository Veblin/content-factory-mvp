# DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxx

# Qwen (通义千问) API Key — 阿里云 DashScope
# 模型: qwen-plus, qwen-max, qwen-turbo
QWEN_API_KEY=sk-xxx

# MiniMax API Key
# 模型: MiniMax-M2.7, MiniMax-M2.7-highspeed, MiniMax-M2.5
MINIMAX_API_KEY=sk-xxx

# 按 Agent 配置模型
SCOUT_MODEL=deepseek-chat
STRATEGIST_MODEL=MiniMax-M2.7
RESONANCE_MODEL=qwen-plus
EVIDENCE_MODEL=qwen-plus
WRITER_MODEL=MiniMax-M2.7
ART_DIRECTOR_MODEL=deepseek-chat

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxx

# Qwen (通义千问) API Key — 阿里云 DashScope
# 模型: qwen-plus, qwen-max, qwen-turbo
QWEN_API_KEY=sk-xxx

# 按 Agent 配置模型
SCOUT_MODEL=deepseek-chat
STRATEGIST_MODEL=deepseek-chat
RESONANCE_MODEL=deepseek-chat
EVIDENCE_MODEL=deepseek-chat
WRITER_MODEL=deepseek-chat
ART_DIRECTOR_MODEL=deepseek-chat
